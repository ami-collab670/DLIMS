# LSIMS Environment Variables
# Copy this file to .env and fill in production values.
# In development, all values have safe defaults — you don't need a .env file.

# Required in production (DEBUG=False). Generate with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=

# Set to False for production
DJANGO_DEBUG=True

# Comma-separated hostnames for production (e.g. "lsims.ministry.gov,api.lsims.gov")
DJANGO_ALLOWED_HOSTS=

# PostgreSQL connection string (Render.com provides this automatically)
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=

# Email settings for password reset OTPs.
# Local development defaults to console email output.
# For production SMTP, set DJANGO_EMAIL_BACKEND to:
# django.core.mail.backends.smtp.EmailBackend
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DJANGO_EMAIL_HOST=
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_HOST_USER=
DJANGO_EMAIL_HOST_PASSWORD=
DJANGO_EMAIL_USE_TLS=True
DJANGO_DEFAULT_FROM_EMAIL=noreply@lsims.local
