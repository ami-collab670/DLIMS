{
  "kind": "singleType",
  "collectionName": "site_settings",
  "info": {
    "singularName": "site-setting",
    "pluralName": "site-settings",
    "displayName": "Site Setting",
    "description": "Global branding and public navigation"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "siteName": {
      "type": "string",
      "required": true,
      "default": "LSIMS",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "footerTagline": {
      "type": "text",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "navLinks": {
      "type": "component",
      "repeatable": true,
      "component": "navigation.nav-link",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "footerLinkGroups": {
      "type": "component",
      "repeatable": true,
      "component": "navigation.footer-link-group",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "socialLinks": {
      "type": "component",
      "repeatable": true,
      "component": "navigation.social-link",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    }
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  }
}
