{
  "kind": "singleType",
  "collectionName": "site_settings",
  "info": {
    "singularName": "site-setting",
    "pluralName": "site-settings",
    "displayName": "Site Setting",
    "description": "Global branding and public navigation"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "siteName": {
      "type": "string",
      "required": true,
      "default": "LSIMS"
    },
    "footerTagline": {
      "type": "text",
      "required": true
    },
    "navLinks": {
      "type": "component",
      "repeatable": true,
      "component": "navigation.nav-link"
    },
    "footerLinkGroups": {
      "type": "component",
      "repeatable": true,
      "component": "navigation.footer-link-group"
    },
    "socialLinks": {
      "type": "component",
      "repeatable": true,
      "component": "navigation.social-link"
    }
  }
}
