    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text",
      "required": true
    },
    "publishedDate": {
      "type": "string",
      "required": true
    },
    "category": {
      "type": "string",
      "required": true
    },
    "body": {
      "type": "blocks"
    },
    "seoDescription": {
      "type": "text"
    }
  }
}
