# LSIMS Environment Variables
# Copy this file to .env and fill in production values.
# In development, all values have safe defaults — you don't need a .env file.

# Required in production (DEBUG=False). Generate with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=

# Set to False for production
DJANGO_DEBUG=True

# Comma-separated hostnames for production (e.g. "lsims.ministry.gov,api.lsims.gov")
DJANGO_ALLOWED_HOSTS=

# PostgreSQL — pick one:
#
# Full stack (DB + API + Vite) from repo root:  docker compose up --build
#   → backend gets DATABASE_URL from compose; you do not need DATABASE_URL here for Docker.
#
# API on host + Postgres in Docker only (legacy port): map host 5433 → db
DATABASE_URL=postgres://lsims:lsims_dev@127.0.0.1:5433/lsims
